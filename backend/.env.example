# AquaSense Backend — Environment Variables Template
# Copy this file to .env and fill in real values before running the server
# See ENV_SETUP.md in the project root for step-by-step instructions per key

# ── GROQ AI — Primary AI Engine ──────────────────────────────────────────────
GROQ_API_KEY_1=            # Primary Groq key — console.groq.com → API Keys → Create key
GROQ_API_KEY_2=            # Backup Groq key — second account or second key on same account
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# ── SENTINEL HUB — Satellite Data ─────────────────────────────────────────────
SENTINEL_CLIENT_ID=        # OAuth2 Client ID — apps.sentinel-hub.com → OAuth Clients tab
SENTINEL_CLIENT_SECRET=    # OAuth2 Client Secret — shown ONCE at creation, copy immediately
SENTINEL_INSTANCE_ID=      # Configuration Instance ID — Sentinel Hub Dashboard → Configurations
SENTINEL_BASE_URL=https://services.sentinel-hub.com
SENTINEL_TOKEN_URL=https://services.sentinel-hub.com/auth/realms/main/protocol/openid-connect/token

# ── OPEN-METEO — Weather & Rainfall (no key required) ────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ── OPENAQ — Pollution Proxy ──────────────────────────────────────────────────
OPENAQ_BASE_URL=https://api.openaq.org/v3
OPENAQ_API_KEY=            # Free key from openaq.org/register — optional for hackathon demo

# ── FASTAPI INTERNAL ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./aquasense.db
INTERNAL_API_KEY=          # Generate: python -c "import secrets; print(secrets.token_hex(16))"

# ── DEPLOYMENT ────────────────────────────────────────────────────────────────
BACKEND_URL=               # Full ngrok HTTPS URL — update every ngrok session
ENV=development
