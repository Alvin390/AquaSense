# AquaSense Backend — Environment Variables
# Copy this file to .env and fill in real values before running the server

# ── Sentinel Hub (satellite data) ─────────────────────────────────────────────
SENTINEL_HUB_CLIENT_ID=your_sentinel_hub_client_id_here
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_hub_client_secret_here

# ── Groq AI (Llama 3 inference) ───────────────────────────────────────────────
# Two keys for rotation — if key 1 hits rate limit, key 2 is used automatically
GROQ_API_KEY_1=gsk_your_first_groq_api_key_here
GROQ_API_KEY_2=gsk_your_second_groq_api_key_here

# ── OpenAQ (pollution data, optional) ─────────────────────────────────────────
OPENAQ_API_KEY=your_openaq_api_key_here

# ── Admin API key (protects POST /sources/{id}/refresh) ───────────────────────
ADMIN_API_KEY=set_a_strong_random_string_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./aquasense.db

# ── Server ─────────────────────────────────────────────────────────────────────
DEBUG=true
PORT=8000
